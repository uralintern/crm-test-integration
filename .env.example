# ============================================================
# Пример .env для CRM + модуля тестирования
#
# Для боевого сервера заказчика используются:
# CRM: https://meetuppoint.ru
# Тестирование: https://tests.meetuppoint.ru
# VPS: 5.181.108.146
#
# Скопируйте файл в .env и замените все значения ВСТАВЬ_...
# Суперюзер CRM создается вручную:
# docker compose exec backend python manage.py createsuperuser
# ============================================================

APP_DOMAIN=meetuppoint.ru
TESTING_DOMAIN=tests.meetuppoint.ru

VITE_API_BASE=
VITE_USE_MOCK=false
VITE_TESTING_URL=https://tests.meetuppoint.ru

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=ВСТАВЬ_ДЛИННЫЙ_СЕКРЕТНЫЙ_КЛЮЧ_DJANGO
DJANGO_ALLOWED_HOSTS=meetuppoint.ru,5.181.108.146,localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=https://meetuppoint.ru
DJANGO_CORS_ALLOW_ALL_ORIGINS=0
DJANGO_CORS_ALLOWED_ORIGINS=https://meetuppoint.ru,https://tests.meetuppoint.ru
DJANGO_CACHE_DIR=/app/.cache

DB_NAME=crm_bd
DB_USER=crm_user
DB_PASSWORD=ВСТАВЬ_ПАРОЛЬ_БАЗЫ_CRM
DB_HOST=db
DB_PORT=5432

TESTING_SERVICE_TOKEN=ВСТАВЬ_ОБЩИЙ_СЕКРЕТНЫЙ_ТОКЕН_CRM_И_TESTING
TESTING_SERVICE_URL=https://tests.meetuppoint.ru
TESTING_SSO_TICKET_TTL_SECONDS=300

TESTING_DB_NAME=test_constructor
TESTING_DB_USER=testing_user
TESTING_DB_PASSWORD=ВСТАВЬ_ПАРОЛЬ_БАЗЫ_ТЕСТИРОВАНИЯ
TESTING_ADMIN_EMAIL=ВСТАВЬ_EMAIL_АДМИНА_ТЕСТИРОВАНИЯ
TESTING_ADMIN_PASSWORD=ВСТАВЬ_ПАРОЛЬ_АДМИНА_ТЕСТИРОВАНИЯ
TESTING_JWT_SECRET=ВСТАВЬ_ДЛИННЫЙ_СЕКРЕТ_JWT_ТЕСТИРОВАНИЯ
TESTING_JWT_TTL_HOURS=24

VK_ENABLED=1
VK_GROUP_ID=ВСТАВЬ_ID_ГРУППЫ_ВК_БЕЗ_CLUB
VK_ACCESS_TOKEN=ВСТАВЬ_ТОКЕН_СООБЩЕСТВА_ВК
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_CALLBACK_SECRET=ВСТАВЬ_SECRET_ИЗ_CALLBACK_API_ВК
VK_CONFIRMATION_CODE=ВСТАВЬ_CONFIRMATION_CODE_ИЗ_CALLBACK_API_ВК
VK_CHAT_LINK_BASE_URL=https://meetuppoint.ru
VK_BOT_FRONTEND_URL=https://meetuppoint.ru
VK_ORG_CHAT_URL=
VK_ORG_CHAT_PEER_ID=0
VK_CHAT_LINK_MAX_AGE_SECONDS=2592000
VK_REQUEST_TIMEOUT_SECONDS=5

AUTOMATION_INTERVAL_SECONDS=60
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1
