# Local domains used by docker-compose.local.yml.
APP_DOMAIN=localhost
TESTING_DOMAIN=testing.localhost

# CRM frontend.
# Empty VITE_API_BASE means frontend calls /api on the same host.
VITE_API_BASE=
VITE_USE_MOCK=false
VITE_TESTING_URL=http://testing.localhost

# Django / CRM backend.
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=local-dev-django-secret-key-not-for-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://testing.localhost
DJANGO_CORS_ALLOW_ALL_ORIGINS=1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://testing.localhost
DJANGO_CACHE_DIR=/app/.cache

# PostgreSQL for CRM.
DB_NAME=crm_bd
DB_USER=crm_user
DB_PASSWORD=crm_local_password
DB_HOST=db
DB_PORT=5432

# CRM <-> testing module integration.
# This token must be the same for CRM backend and testing-backend.
TESTING_SERVICE_TOKEN=local-testing-service-token
TESTING_SERVICE_URL=http://testing.localhost
TESTING_SSO_TICKET_TTL_SECONDS=300

# PostgreSQL for testing module.
TESTING_DB_NAME=test_constructor
TESTING_DB_USER=testing_user
TESTING_DB_PASSWORD=testing_local_password

# Initial admin account for testing module.
# This is not the Django CRM superuser.
TESTING_ADMIN_EMAIL=testing-admin@example.com
TESTING_ADMIN_PASSWORD=testing-admin-password
TESTING_JWT_SECRET=local-testing-jwt-secret-not-for-production
TESTING_JWT_TTL_HOURS=24

# VK integration is disabled locally by default.
VK_ENABLED=0
VK_GROUP_ID=0
VK_ACCESS_TOKEN=local-disabled
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_CALLBACK_SECRET=local-disabled
VK_CONFIRMATION_CODE=local-disabled
VK_CHAT_LINK_BASE_URL=http://localhost
VK_BOT_FRONTEND_URL=http://localhost
VK_ORG_CHAT_URL=
VK_ORG_CHAT_PEER_ID=0
VK_CHAT_LINK_MAX_AGE_SECONDS=2592000
VK_REQUEST_TIMEOUT_SECONDS=5

# Automation worker.
AUTOMATION_INTERVAL_SECONDS=60

# Container startup flags.
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1

# Internship parser microservice
PARSER_DB_NAME=internships
PARSER_DB_USER=parser_user
PARSER_DB_PASSWORD=parser_local_password
PARSER_APP_PORT=8080

# Airflow ETL for internships
AIRFLOW_UID=50000
AIRFLOW_PORT=8081
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_FERNET_KEY=lrwQVgqN5fmyOD3GhlzmZaFrnU83bxm_LMFSrKsKj-s=
AIRFLOW_JWT_SECRET=ed7f09f040e983a5a8bd907a5b0c9d2c41fb736f8888cfbc67778b32e3b8d404
